<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>316 Développement — Expert CIR & CII</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --gris:#4f5a53; --gris-dark:#3a4340; --gris-lite:#8fa88a;
  --vert:#72be64; --vert-dark:#55a048; --vert-lite:#90d183;
  --bg:#0d1210; --bg2:#141c16; --bg3:#1c2820;
  --border:rgba(114,190,100,0.2); --text:#e8f0e6; --text2:#8fa88a;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.6}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(13,18,16,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 5vw;height:68px;display:flex;align-items:center;gap:20px}
nav img{height:46px;object-fit:contain}
.nav-links{margin-left:auto;display:flex;gap:6px;align-items:center}
.nav-link{color:var(--text2);text-decoration:none;padding:6px 14px;border-radius:8px;font-size:14px;transition:all .15s}
.nav-link:hover{color:var(--text);background:rgba(114,190,100,.1)}
.nav-cta{background:linear-gradient(135deg,var(--vert),var(--vert-dark));color:#fff!important;font-weight:600;border-radius:8px;padding:8px 18px!important}
.nav-cta:hover{opacity:.88;background:linear-gradient(135deg,var(--vert),var(--vert-dark))!important}

/* HERO */
.hero{min-height:88vh;display:flex;align-items:center;padding:80px 5vw;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 70% 50%,rgba(114,190,100,.08) 0%,transparent 70%)}
.hero-content{max-width:620px;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(114,190,100,.12);border:1px solid var(--border);border-radius:20px;padding:5px 14px;font-size:12px;color:var(--vert);margin-bottom:28px}
.hero-badge-dot{width:7px;height:7px;border-radius:50%;background:var(--vert);box-shadow:0 0 6px var(--vert)}
h1{font-family:'Syne',sans-serif;font-size:clamp(38px,5vw,62px);font-weight:800;line-height:1.1;margin-bottom:24px}
h1 span{background:linear-gradient(135deg,var(--vert),var(--vert-lite));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-desc{font-size:17px;color:var(--text2);max-width:520px;margin-bottom:36px;font-weight:300}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.btn-hero-p{background:linear-gradient(135deg,var(--vert),var(--vert-dark));color:#fff;border:none;border-radius:10px;padding:13px 26px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:transform .15s,box-shadow .15s}
.btn-hero-p:hover{transform:translateY(-2px);box-shadow:0 6px 28px rgba(114,190,100,.35)}
.btn-hero-s{background:transparent;color:var(--text);border:1px solid var(--border);border-radius:10px;padding:13px 26px;font-family:'DM Sans',sans-serif;font-size:15px;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:all .15s}
.btn-hero-s:hover{border-color:var(--vert);color:var(--vert)}
.hero-stats{display:flex;gap:32px;margin-top:52px;padding-top:32px;border-top:1px solid var(--border);flex-wrap:wrap}
.stat-num{font-family:'Syne',sans-serif;font-size:32px;font-weight:800;color:var(--vert)}
.stat-lbl{font-size:13px;color:var(--text2);margin-top:2px}

/* SERVICES */
.section{padding:80px 5vw}
.section-tag{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--vert);margin-bottom:12px}
h2{font-family:'Syne',sans-serif;font-size:clamp(28px,3vw,42px);font-weight:800;margin-bottom:16px}
.section-sub{font-size:16px;color:var(--text2);max-width:560px;font-weight:300}
.cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:48px}
.service-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:28px;transition:border-color .2s,transform .2s}
.service-card:hover{border-color:rgba(114,190,100,.5);transform:translateY(-3px)}
.service-icon{font-size:32px;margin-bottom:16px}
.service-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;margin-bottom:10px}
.service-desc{font-size:14px;color:var(--text2);line-height:1.6}
.service-tag{display:inline-block;margin-top:14px;background:rgba(114,190,100,.12);border:1px solid var(--border);border-radius:5px;padding:2px 9px;font-size:11px;color:var(--vert);font-weight:500}

/* CTA SECTION */
.cta-section{background:linear-gradient(135deg,var(--bg2) 0%,#0f2216 100%);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:80px 5vw;text-align:center}
.cta-section h2{margin-bottom:16px}
.cta-section p{color:var(--text2);font-size:16px;margin-bottom:36px;font-weight:300}

/* PROCESS */
.process-list{display:flex;flex-direction:column;gap:0;max-width:680px;margin:48px auto 0}
.process-step{display:flex;gap:20px;padding:24px 0;border-bottom:1px solid var(--border);align-items:flex-start}
.process-step:last-child{border-bottom:none}
.step-num{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--vert),var(--gris));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:15px;flex-shrink:0;color:#fff}
.step-title{font-weight:600;margin-bottom:5px}
.step-desc{font-size:13px;color:var(--text2)}

/* AGENT PROMO */
.agent-promo{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:48px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;margin-top:60px}
.agent-promo h2{margin-bottom:14px}
.agent-promo p{color:var(--text2);font-size:15px;margin-bottom:28px;font-weight:300}
.agent-features{display:flex;flex-direction:column;gap:10px;margin-bottom:28px}
.agent-feature{display:flex;align-items:center;gap:10px;font-size:14px}
.agent-feature::before{content:'✓';color:var(--vert);font-weight:700;flex-shrink:0}
.agent-preview{background:var(--bg3);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.agent-preview-head{background:linear-gradient(135deg,#0f1f15,#1c2820);padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.agent-preview-head img{height:30px}
.agent-preview-msgs{padding:16px;display:flex;flex-direction:column;gap:10px}
.prev-msg{display:flex;gap:8px}
.prev-av{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,var(--vert),var(--gris));display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:800;color:#fff;flex-shrink:0}
.prev-bbl{background:var(--bg2);border:1px solid var(--border);border-radius:9px;padding:7px 11px;font-size:12px;line-height:1.55;color:var(--text)}

/* FOOTER */
footer{background:var(--bg2);border-top:1px solid var(--border);padding:40px 5vw;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
footer img{height:36px}
.footer-text{font-size:13px;color:var(--text2)}
.footer-links{display:flex;gap:20px}
.footer-link{color:var(--text2);text-decoration:none;font-size:13px;transition:color .15s}
.footer-link:hover{color:var(--vert)}

@media(max-width:768px){
  nav{padding:0 4vw}
  .nav-links{gap:2px}
  .nav-link{padding:5px 9px;font-size:13px}
  .hero{padding:60px 4vw}
  .section{padding:60px 4vw}
  .agent-promo{grid-template-columns:1fr}
  .agent-preview{display:none}
  footer{flex-direction:column;text-align:center}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <img src="data:image/png;base64," alt="316 Développement">
  <div class="nav-links">
    <a class="nav-link" href="#services">Services</a>
    <a class="nav-link" href="#methode">Méthode</a>
    <a class="nav-link" href="#agent">Agent IA</a>
    <a class="nav-link" href="#contact">Contact</a>
    <a class="nav-link nav-cta" href="agent.html">💬 Tester l'agent</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge"><div class="hero-badge-dot"></div>Cabinet expert en financement R&D</div>
    <h1>Maximisez votre <span>CIR & CII</span> en toute sécurité</h1>
    <p class="hero-desc">316 Développement structure et rédige vos dossiers de Crédit d'Impôt Recherche et d'Innovation. Méthodologie Frascati rigoureuse, défense face aux contrôles fiscaux.</p>
    <div class="hero-btns">
      <a class="btn-hero-p" href="agent.html">💬 Parler à l'expert IA</a>
      <a class="btn-hero-s" href="#services">Nos services →</a>
    </div>
    <div class="hero-stats">
      <div><div class="stat-num">30%</div><div class="stat-lbl">Taux CIR sur vos dépenses R&D</div></div>
      <div><div class="stat-num">100%</div><div class="stat-lbl">Dossiers validés au contrôle</div></div>
      <div><div class="stat-num">PME</div><div class="stat-lbl">Spécialistes secteur industriel</div></div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="section" id="services">
  <div class="section-tag">Nos expertises</div>
  <h2>Un accompagnement complet<br>sur toute la chaîne CIR/CII</h2>
  <p class="section-sub">De l'identification des travaux éligibles à la défense en cas de contrôle fiscal.</p>
  <div class="cards-grid">
    <div class="service-card">
      <div class="service-icon">🔬</div>
      <div class="service-title">Crédit d'Impôt Recherche</div>
      <p class="service-desc">Identification des verrous technologiques, état de l'art, structuration des hypothèses selon le Manuel de Frascati. Dossier défendable face à la DGFiP.</p>
      <span class="service-tag">Art. 244 quater B CGI</span>
    </div>
    <div class="service-card">
      <div class="service-icon">💡</div>
      <div class="service-title">Crédit d'Impôt Innovation</div>
      <p class="service-desc">CII pour PME innovantes : prototypes, pilotes, nouvelles fonctionnalités. Jusqu'à 30% de 400K€ de dépenses éligibles par exercice fiscal.</p>
      <span class="service-tag">PME jusqu'à 120K€</span>
    </div>
    <div class="service-card">
      <div class="service-icon">📋</div>
      <div class="service-title">Dossier de justification</div>
      <p class="service-desc">Rédaction complète du dossier technique : état de l'art sourcé (brevets, publications), verrous documentés, hypothèses H1/H2/H3 avec résultats mesurés.</p>
      <span class="service-tag">Défense contrôle fiscal</span>
    </div>
    <div class="service-card">
      <div class="service-icon">💶</div>
      <div class="service-title">Calcul des dépenses éligibles</div>
      <p class="service-desc">Optimisation des assiettes : personnel R&D, sous-traitance agréée, amortissements, prototypes. Cerfa 2069-A-SD et annexes justificatives.</p>
      <span class="service-tag">Optimisation fiscale</span>
    </div>
    <div class="service-card">
      <div class="service-icon">⚖️</div>
      <div class="service-title">Rescrit fiscal CIR</div>
      <p class="service-desc">Sécurisation préalable via rescrit auprès du Ministère de la Recherche et de la DGFiP. Gestion du risque de contrôle et accompagnement en cas de redressement.</p>
      <span class="service-tag">Sécurité juridique</span>
    </div>
    <div class="service-card">
      <div class="service-icon">🏭</div>
      <div class="service-title">Secteurs industriels</div>
      <p class="service-desc">Expertise particulière en agroalimentaire, industrie manufacturière, connectique automobile, équipements agricoles et logiciel embarqué.</p>
      <span class="service-tag">PME & ETI</span>
    </div>
  </div>
</section>

<!-- AGENT PROMO -->
<section class="section" id="agent" style="padding-top:0">
  <div class="agent-promo">
    <div>
      <div class="section-tag">Nouveau</div>
      <h2>Votre expert CIR/CII disponible 24h/24</h2>
      <p>Notre agent IA répond instantanément à vos questions sur le CIR, le CII, les verrous technologiques et vos dépenses éligibles.</p>
      <div class="agent-features">
        <div class="agent-feature">Qualification immédiate de vos travaux R&D</div>
        <div class="agent-feature">Calcul estimatif de votre crédit d'impôt</div>
        <div class="agent-feature">Méthodologie Frascati expliquée</div>
        <div class="agent-feature">Conseils sur l'état de l'art et les verrous</div>
      </div>
      <a class="btn-hero-p" href="agent.html">💬 Accéder à l'agent →</a>
    </div>
    <div class="agent-preview">
      <div class="agent-preview-head">
        <img src="data:image/png;base64," alt="316">
        <div style="font-size:12px;color:#8fa88a">Agent CIR/CII · 316 Développement</div>
      </div>
      <div class="agent-preview-msgs">
        <div class="prev-msg">
          <div class="prev-av">316</div>
          <div class="prev-bbl">Bonjour ! Je suis votre expert <strong style="color:#72be64">CIR/CII</strong>. Décrivez vos travaux de R&D pour que j'évalue leur éligibilité.</div>
        </div>
        <div class="prev-msg" style="flex-direction:row-reverse">
          <div class="prev-av" style="background:linear-gradient(135deg,#4f5a53,#3a4340);font-size:14px">👤</div>
          <div class="prev-bbl" style="background:rgba(114,190,100,.1);border-color:rgba(114,190,100,.3)">On développe un nouveau moule perforé en biomatériau pour canelés industriels.</div>
        </div>
        <div class="prev-msg">
          <div class="prev-av">316</div>
          <div class="prev-bbl">Excellent cas ! Votre projet présente des <strong style="color:#72be64">verrous technologiques</strong> potentiels : tenue mécanique du biomatériau aux cycles thermiques répétés (180–220°C)…</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MÉTHODE -->
<section class="section" id="methode" style="text-align:center">
  <div class="section-tag">Notre approche</div>
  <h2>Une méthodologie éprouvée</h2>
  <p class="section-sub" style="margin:0 auto">Chaque dossier suit un processus rigoureux basé sur le Manuel de Frascati et les exigences DGFiP.</p>
  <div class="process-list">
    <div class="process-step">
      <div class="step-num">1</div>
      <div><div class="step-title">Qualification des travaux</div><div class="step-desc">Entretien technique pour identifier les activités de R&D ou d'innovation parmi vos projets. Distinction CIR / CII / hors périmètre.</div></div>
    </div>
    <div class="process-step">
      <div class="step-num">2</div>
      <div><div class="step-title">État de l'art & verrous</div><div class="step-desc">Recherche documentaire rigoureuse (Espacenet, publications scientifiques, normes). Identification et formulation des incertitudes technologiques.</div></div>
    </div>
    <div class="process-step">
      <div class="step-num">3</div>
      <div><div class="step-title">Calcul des dépenses éligibles</div><div class="step-desc">Ventilation des coûts éligibles : personnel R&D, sous-traitance agréée, amortissements, prototypes. Optimisation de l'assiette.</div></div>
    </div>
    <div class="process-step">
      <div class="step-num">4</div>
      <div><div class="step-title">Rédaction du dossier</div><div class="step-desc">Production du dossier de justification complet, cohérent avec le cerfa 2069-A-SD. Argumentaire technique défendable.</div></div>
    </div>
    <div class="process-step">
      <div class="step-num">5</div>
      <div><div class="step-title">Suivi & défense</div><div class="step-desc">Accompagnement sur la durée : révisions annuelles, rescrit fiscal si nécessaire, assistance en cas de contrôle DGFiP.</div></div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="section-tag">Commencez maintenant</div>
  <h2>Estimez votre crédit d'impôt</h2>
  <p>Posez vos questions à notre agent IA ou contactez-nous directement pour un premier échange.</p>
  <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
    <a class="btn-hero-p" href="agent.html">💬 Parler à l'expert IA</a>
    <a class="btn-hero-s" href="mailto:contact@316developpement.fr">✉️ Nous contacter</a>
  </div>
</section>


<!-- CONTACT -->
<section class="section" id="contact" style="padding-top:0">
  <div style="background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:48px;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start">
    <div>
      <div class="section-tag">Nous contacter</div>
      <h2 style="margin-bottom:16px">Parlons de votre projet R&D</h2>
      <p style="color:var(--text2);font-size:15px;margin-bottom:32px;font-weight:300">Notre équipe est disponible pour analyser vos travaux et estimer votre potentiel CIR/CII. Premier échange gratuit et sans engagement.</p>
      <div style="display:flex;flex-direction:column;gap:18px">
        <div style="display:flex;align-items:center;gap:14px">
          <div style="width:44px;height:44px;border-radius:50%;background:rgba(114,190,100,.15);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">📧</div>
          <div>
            <div style="font-size:12px;color:var(--text2);margin-bottom:2px">Email</div>
            <a href="mailto:contact@316developpement.fr" style="color:var(--vert);font-weight:500;text-decoration:none;font-size:15px">contact@316developpement.fr</a>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:14px">
          <div style="width:44px;height:44px;border-radius:50%;background:rgba(114,190,100,.15);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">📞</div>
          <div>
            <div style="font-size:12px;color:var(--text2);margin-bottom:2px">Téléphone</div>
            <a href="tel:0649475848" style="color:var(--vert);font-weight:500;text-decoration:none;font-size:15px">06 49 47 58 48</a>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:14px">
          <div style="width:44px;height:44px;border-radius:50%;background:rgba(114,190,100,.15);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">📍</div>
          <div>
            <div style="font-size:12px;color:var(--text2);margin-bottom:2px">Zone d'intervention</div>
            <span style="font-size:15px">Nouvelle-Aquitaine &amp; national</span>
          </div>
        </div>
      </div>
    </div>
    <div>
      <div style="font-weight:700;font-size:15px;margin-bottom:18px">✉️ Demande de contact rapide</div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Prénom et Nom *</label>
          <input id="ct-nom" placeholder="Marie Martin" style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:inherit;font-size:13px;outline:none"></div>
        <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Email *</label>
          <input id="ct-email" type="email" placeholder="marie@entreprise.fr" style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:inherit;font-size:13px;outline:none"></div>
        <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Téléphone</label>
          <input id="ct-tel" placeholder="06 XX XX XX XX" style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:inherit;font-size:13px;outline:none"></div>
        <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Société *</label>
          <input id="ct-societe" placeholder="Acme SAS" style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:inherit;font-size:13px;outline:none"></div>
        <div><label style="font-size:11px;color:var(--text2);display:block;margin-bottom:4px">Message (optionnel)</label>
          <textarea id="ct-msg" rows="3" placeholder="Décrivez brièvement vos travaux de R&D…" style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 12px;color:var(--text);font-family:inherit;font-size:13px;outline:none;resize:vertical"></textarea></div>
        <div id="ct-err" style="color:#f87171;font-size:12px;display:none"></div>
        <div id="ct-ok" style="color:#72be64;font-size:13px;font-weight:500;display:none">✅ Message envoyé ! Nous vous répondons sous 24h.</div>
        <button onclick="sendContactForm()" style="background:linear-gradient(135deg,#72be64,#55a048);border:none;border-radius:10px;padding:12px;color:#fff;font-family:inherit;font-size:14px;font-weight:600;cursor:pointer">Envoyer ma demande →</button>
      </div>
    </div>
  </div>
</section>

<script>
function sendContactForm() {
  const nom    = document.getElementById("ct-nom").value.trim();
  const email  = document.getElementById("ct-email").value.trim();
  const societe= document.getElementById("ct-societe").value.trim();
  const tel    = document.getElementById("ct-tel").value.trim();
  const msg    = document.getElementById("ct-msg").value.trim();
  const err    = document.getElementById("ct-err");
  const ok     = document.getElementById("ct-ok");
  if (!nom || !email || !societe) { err.textContent = "⚠️ Renseignez les champs obligatoires (*)"; err.style.display = "block"; return; }
  err.style.display = "none";
  // Sauvegarde en localStorage
  const contacts = JSON.parse(localStorage.getItem("316dev_contacts") || "[]");
  contacts.push({ prenom: nom.split(" ")[0], nom: nom.split(" ").slice(1).join(" "), email, tel, societe, interet: "À qualifier", statut: "Formulaire accueil", notes: msg, date: new Date().toLocaleDateString("fr-FR") });
  localStorage.setItem("316dev_contacts", JSON.stringify(contacts));
    fetch("/api/save-contact", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ nom, email, societe, tel, source: "Formulaire accueil" })
    }).catch(e => console.warn("Sheet:", e));
  ok.style.display = "block";
  ["ct-nom","ct-email","ct-tel","ct-societe","ct-msg"].forEach(id => document.getElementById(id).value = "");
  // Ouvre le client mail en parallèle
  const subject = encodeURIComponent("Demande de contact CIR/CII — " + societe);
  const body    = encodeURIComponent("Nom : " + nom + "\nEmail : " + email + "\nTél : " + (tel||"—") + "\nSociété : " + societe + "\n\nMessage : " + (msg||"—"));
  window.open("mailto:contact@316developpement.fr?subject=" + subject + "&body=" + body);
}
<\/script>

