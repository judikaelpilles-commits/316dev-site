{
  "version": 2,
  "routes": [
    { "src": "/api/chat",            "dest": "/api/chat.js" },
    { "src": "/api/create-checkout", "dest": "/api/create-checkout.js" },
    { "src": "/api/verify-payment",  "dest": "/api/verify-payment.js" },
    { "src": "/api/save-contact",    "dest": "/api/save-contact.js" },
    { "src": "/api/get-contacts",    "dest": "/api/get-contacts.js" },
    { "src": "/agent",               "dest": "/agent.html" },
    { "src": "/agent.html",          "dest": "/agent.html" },
    { "src": "/",                    "dest": "/index.html" },
    { "src": "/(.*)",                "dest": "/$1" }
  ]
}
